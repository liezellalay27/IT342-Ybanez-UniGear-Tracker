<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    android:background="@drawable/home_card_shell"
    android:orientation="vertical"
    android:padding="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="210dp"
        android:background="#CACBD0"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvEquipmentInitial"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="M"
            android:textColor="#550000"
            android:textSize="42sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvEquipmentName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:paddingHorizontal="12dp"
        android:textColor="#550000"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvEquipmentCategory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:paddingHorizontal="12dp"
        android:textColor="#666666"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvEquipmentLocation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:paddingHorizontal="12dp"
        android:textColor="#666666"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/tvEquipmentStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginStart="12dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/status_available_bg"
        android:paddingHorizontal="10dp"
        android:paddingVertical="6dp"
        android:text="Available"
        android:textColor="#2E7D32"
        android:textSize="12sp"
        android:textStyle="bold" />

</LinearLayout>
