# Backend Configuration - Copy to backend/.env and fill in actual values
# DO NOT COMMIT backend/.env - it's in .gitignore

# Server
SERVER_PORT=8080
APP_NAME=unigear-tracker

# Database (Supabase PostgreSQL)
DB_URL=jdbc:postgresql://your-host:6543/postgres
DB_USERNAME=postgres
DB_PASSWORD=your_db_password

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# JWT Security
JWT_SECRET=your_jwt_secret_key_minimum_32_characters
JWT_EXPIRATION=86400000

# Admin Bootstrap
ADMIN_EMAIL=admin@unigear.com
ADMIN_PASSWORD=your_secure_password
ADMIN_BOOTSTRAP_ENABLED=true

# Google OAuth2 (from Google Cloud Console)
GOOGLE_CLIENT_ID=your_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret_here

# OAuth Redirect
OAUTH2_REDIRECT_URI=http://localhost:3000
